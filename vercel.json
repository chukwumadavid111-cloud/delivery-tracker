{
  "buildCommand": "npm --prefix frontend run build",
  "outputDirectory": "frontend/build",
  "framework": "react",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend.herokuapp.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
