{
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm --prefix backend start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthchecks": {
      "httpPath": "/api/health"
    }
  },
  "envConfigured": ["NODE_ENV", "PORT"]
}
